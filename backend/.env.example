# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password_here
DB_NAME=news_app

# NewsAPI — get free key at https://newsapi.org
NEWS_API_KEY=newsapi_key_here

# OpenAI — get key at https://platform.openai.com
OPENAI_API_KEY=openai_key_here

# App settings
TOKEN_TTL_DAYS=7
DEBUG=false
SQLALCHEMY_ECHO=false
CORS_ORIGINS=*

# Admin — set a strong random string to protect /admin/scrape
ADMIN_SECRET=change_me_to_a_strong_random_string
